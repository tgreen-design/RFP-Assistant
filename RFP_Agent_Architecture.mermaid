flowchart TD
    subgraph INPUTS["INPUTS & TRIGGERS"]
        A([📧 RFP Email\nInbound])
        B([⚡ Salesforce\nStage Change Webhook])
        C([💬 Slack\n@RFP-Bot Mention])
    end

    subgraph INTAKE["INTAKE LAYER"]
        D[Document Parser\nLlamaParse / Unstructured.io\nPDF · Word · Excel → structured JSON]
        E[Salesforce API\nPull opp data: account,\ncontact, deal size, deadline]
    end

    subgraph BRAIN["CORE AI AGENT  ·  Claude claude-opus-4-6 via Agent SDK"]
        F[Orchestrator\nRoutes tasks to the\nright sub-agent]

        subgraph AGENTS["SUB-AGENTS"]
            G[Go/No-Go Agent\nScores deal viability\nR/Y/G recommendation]
            H[Categorization Agent\nSections → Autopilot /\nNeeds Input / Legal Flag]
            I[Question Agent\nDrafts clarification\nquestion list]
            J[Product Rec Agent\nIndustry + profile analysis\ntrending product match]
            K[Pricing Agent\nCompetitor scrape\nmargin modeling]
            L[Drafting Agent\nRAG-powered response\ngeneration by section]
            M[Brand Agent\nVisual package\ngeneration]
            N[Compliance Agent\nPre-submission\nchecklist]
        end
    end

    subgraph MEMORY["DATA & MEMORY LAYER"]
        O[(Vector Database\nPinecone / pgvector\nRFP response library\nQ&A embeddings)]
        P[(Structured DB\nPostgreSQL\nDeal data · project boards\nmargin floors · owners)]
        Q[(Document Store\nAWS S3 / Google Drive\nRFP files · drafts · outputs)]
    end

    subgraph EXTERNAL["EXTERNAL DATA SOURCES"]
        R[🌐 Competitor Sites\nPlaywright scraper\nVistaprint · Printful · etc.]
        S[🌐 CustomInk.com\nLive pricing scraper]
        T[📊 Trending Product Data\nMerchandising feed]
        U[🎨 Image Generation\nProduct mockup API\nDALL-E / Ideogram]
    end

    subgraph OUTPUTS["OUTPUT & INTEGRATION LAYER"]
        V[📋 Salesforce\nProject board · Tasks\nOpp updates · doc attach]
        W[💬 Slack Bot\nNotifications · assignments\ndraft delivery · approvals]
        X[📄 Document Generator\npython-docx · openpyxl\nFormat-agnostic export]
        Y[📤 Submission\nFormatted response\nReady to send]
    end

    A --> D
